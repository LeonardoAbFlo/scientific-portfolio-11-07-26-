# Required paths
READS_DIR=/path/to/fastq_pass
WORK_DIR=/path/to/klebsiella_analysis
METADATA_TSV=/path/to/sample_metadata.tsv

# Compute resources
THREADS=16
FLYE_MODE=nano-hq

# GTDB-Tk database (required for classification)
GTDBTK_DATA_PATH=/path/to/gtdbtk/release

# Set to 1 to allow the optional cross-genus plasmid rule.
EXCLUDE_CROSS_GENUS_PLASMIDS=0

